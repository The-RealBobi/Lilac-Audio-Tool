<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Level5.AudioTool.Gui"
        x:Class="Level5.AudioTool.Gui.MainWindow"
        Width="1280"
        Height="820"
        MinWidth="1100"
        MinHeight="720"
        Title="L5 Audio Tool"
        Icon="/Assets/icon.ico"
        DragDrop.AllowDrop="True">
  <Grid Margin="18" RowDefinitions="Auto,*" RowSpacing="14">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="16">
      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
        <TextBlock Text="L5 Audio Tool" FontSize="28" FontWeight="Bold" />
        <TextBlock x:Name="VersionTextBlock" VerticalAlignment="Center" Opacity="0.68" />
        <TextBlock x:Name="SubtitleTextBlock" IsVisible="False" />
      </StackPanel>

      <Button x:Name="ExecuteButton"
              Grid.Column="1"
              Content="4. Exportar ACB/AWB"
              Padding="22,10"
              MinWidth="190"
              VerticalAlignment="Center"
              HorizontalContentAlignment="Center"
              Click="OnExecuteClick" />
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="300,12,*,12,360">
      <Border Grid.Column="0" Padding="14" CornerRadius="10" Background="#101C1C1C">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="16">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
              <TextBlock x:Name="FilesHeaderTextBlock" Text="1. Banco" FontWeight="SemiBold" />
              <TextBlock Grid.Row="1"
                         x:Name="BankLabelTextBlock"
                         Text="ACB/AWB"
                         Opacity="0.78" />
              <Button Grid.Row="2"
                      x:Name="BrowseBankButton"
                      Content="Examinar"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      Click="OnBrowseBankClick" />
            </Grid>

            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
              <TextBox x:Name="AcbPathTextBox"
                       Watermark="Banco .acb"
                       IsReadOnly="True"
                       TextWrapping="NoWrap" />
              <TextBox Grid.Row="1"
                       x:Name="AwbPathTextBox"
                       Watermark="Banco .awb"
                       IsReadOnly="True"
                       TextWrapping="NoWrap" />
              <TextBox x:Name="WavPathTextBox" IsVisible="False" IsReadOnly="True" />
              <TextBox x:Name="OutputDirectoryTextBox" IsVisible="False" IsReadOnly="True" />
            </Grid>

            <Border Padding="12" CornerRadius="8" Background="#16232424">
              <StackPanel Spacing="10">
                <TextBlock x:Name="ExportOptionsHeaderTextBlock" Text="Opciones de exportación" FontWeight="SemiBold" />
                <CheckBox x:Name="KeepHcaCheckBox"
                          Content="Guardar audio codificado junto al AWB"
                          IsChecked="True" />
                <CheckBox x:Name="KeepReportsCheckBox"
                          Content="Guardar informes de exportación"
                          IsChecked="False" />
                <CheckBox x:Name="UseModSuffixCheckBox"
                          Content="Añadir sufijo .mod"
                          IsChecked="True" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <GridSplitter Grid.Column="1"
                    Width="8"
                    Margin="1,0"
                    Background="#304F807D"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    ShowsPreview="True"
                    Cursor="SizeWestEast" />

      <Border Grid.Column="2" Padding="14" CornerRadius="10" Background="#101C1C1C">
        <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <TextBlock x:Name="EntriesHeaderTextBlock"
                       Text="Entradas AWB"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button x:Name="InspectAwbButton"
                    Grid.Column="1"
                    Content="Leer entradas AWB"
                    Click="OnInspectAwbClick" />
            <Button x:Name="PreviewEntryButton"
                    Grid.Column="2"
                    Content="Reproducir"
                    Click="OnPreviewEntryClick" />
          </Grid>

          <Border Grid.Row="1" Padding="10" CornerRadius="6" Background="#14282929">
            <TextBlock x:Name="SelectedEntryTextBlock"
                       Text="Selecciona una entrada para ver sus nombres asociados."
                       TextWrapping="Wrap" />
          </Border>

          <Grid Grid.Row="2" ColumnDefinitions="118,120,Auto,Auto" ColumnSpacing="8">
            <TextBlock x:Name="ChangesHeaderTextBlock"
                       Text="2. Entrada"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" />
            <ComboBox Grid.Column="1" x:Name="SelectorModeComboBox" SelectedIndex="0" SelectionChanged="OnSelectorChanged">
              <ComboBoxItem Content="ID AWB" />
              <ComboBoxItem Content="Índice" />
            </ComboBox>
            <NumericUpDown Grid.Column="2"
                           x:Name="EntryNumberBox"
                           Width="110"
                           Minimum="0"
                           Maximum="999999"
                           Increment="1"
                           Value="0"
                           ValueChanged="OnSelectorNumberChanged" />
            <Button Grid.Column="3"
                    x:Name="SubstituteButton"
                    Content="Sustituir"
                    Click="OnSubstituteClick" />
          </Grid>

          <DataGrid Grid.Row="3"
                    x:Name="AwbEntriesGrid"
                    RowHeight="34"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    GridLinesVisibility="Horizontal"
                    SelectionChanged="OnAwbEntrySelectionChanged">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="64" />
              <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="64" />
              <DataGridTextColumn Header="Tipo" Binding="{Binding Extension}" Width="70" />
              <DataGridTextColumn Header="Tamaño" Binding="{Binding Size}" Width="92" />
              <DataGridTemplateColumn Header="Nombre" Width="2*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Border ClipToBounds="True">
                      <TextBlock Text="{Binding PrimaryCue}"
                                 TextTrimming="CharacterEllipsis"
                                 TextWrapping="NoWrap"
                                 VerticalAlignment="Center"
                                 ToolTip.Tip="{Binding CueTooltip}" />
                    </Border>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Usos" Binding="{Binding CueReferenceSummary}" Width="64" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="3"
                    Width="8"
                    Margin="1,0"
                    Background="#304F807D"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    ShowsPreview="True"
                    Cursor="SizeWestEast" />

      <Grid Grid.Column="4" RowDefinitions="Auto,12,210,12,*">
        <Border Grid.Row="0" Padding="14" CornerRadius="10" Background="#101C1C1C">
          <StackPanel Spacing="10">
            <TextBlock x:Name="LoopHeaderTextBlock" Text="3. Loop" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <ComboBox x:Name="LoopModeComboBox" SelectedIndex="0" SelectionChanged="OnLoopModeChanged">
                <ComboBoxItem Content="Loop del archivo" />
                <ComboBoxItem Content="Manual" />
                <ComboBoxItem Content="Sin loop" />
              </ComboBox>
              <Button x:Name="UseWavLoopButton"
                      Grid.Column="1"
                      Content="Usar loop detectado"
                      Click="OnUseWavLoopClick" />
              <Button x:Name="PreviewLoopButton"
                      Grid.Column="2"
                      Content="Reproducir loop"
                      Click="OnPreviewLoopClick" />
            </Grid>
            <TextBlock x:Name="LoopSummaryTextBlock"
                       Text="Carga un WAV para ver duración y loop."
                       Opacity="0.75"
                       TextWrapping="Wrap" />
            <Grid ColumnDefinitions="44,*" ColumnSpacing="10">
              <Button x:Name="PlaybackButton"
                      Width="40"
                      Height="74"
                      Content="▶"
                      FontSize="16"
                      Click="OnPlaybackToggleClick" />
              <local:PlaybackTimeline Grid.Column="1"
                                      x:Name="LoopTimeline"
                                      Height="74"
                                      PointerPressed="OnLoopTimelinePointerPressed"
                                      PointerMoved="OnLoopTimelinePointerMoved"
                                      PointerReleased="OnLoopTimelinePointerReleased"
                                      PointerCaptureLost="OnLoopTimelinePointerCaptureLost"
                                      SizeChanged="OnLoopTimelineSizeChanged" />
            </Grid>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <NumericUpDown x:Name="LoopStartBox"
                             Minimum="0"
                             Maximum="0"
                             Increment="1"
                             ValueChanged="OnLoopNumberChanged" />
              <NumericUpDown Grid.Column="1"
                             x:Name="LoopEndBox"
                             Minimum="0"
                             Maximum="0"
                             Increment="1"
                             ValueChanged="OnLoopNumberChanged" />
            </Grid>
          </StackPanel>
        </Border>

        <GridSplitter Grid.Row="1"
                      Height="8"
                      Margin="0,1"
                      Background="#304F807D"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"
                      Cursor="SizeNorthSouth" />

        <Border Grid.Row="2" Padding="14" CornerRadius="10" Background="#101C1C1C">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBlock x:Name="QueueHeaderTextBlock" Text="Cola" FontWeight="SemiBold" VerticalAlignment="Center" />
              <Button x:Name="RemoveReplacementButton"
                      Grid.Column="1"
                      Content="Quitar"
                      Click="OnRemoveReplacementClick" />
              <Button x:Name="ClearReplacementsButton"
                      Grid.Column="2"
                      Content="Limpiar"
                      Click="OnClearReplacementsClick" />
            </Grid>
            <TextBlock Grid.Row="1"
                       x:Name="CommandPreviewTextBlock"
                       Text="Sin comando preparado."
                       Opacity="0.75"
                       TextWrapping="Wrap" />
            <DataGrid Grid.Row="2"
                      x:Name="ReplacementQueueGrid"
                      RowHeight="32"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      SelectionChanged="OnReplacementSelectionChanged">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Modo" Binding="{Binding Mode}" Width="62" />
                <DataGridTextColumn Header="Entrada" Binding="{Binding Entry}" Width="76" />
                <DataGridTemplateColumn Header="Audio" Width="*">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Border ClipToBounds="True">
                        <TextBlock Text="{Binding AudioName}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center"
                                   ToolTip.Tip="{Binding AudioPath}" />
                      </Border>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Border>

        <GridSplitter Grid.Row="3"
                      Height="8"
                      Margin="0,1"
                      Background="#304F807D"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"
                      Cursor="SizeNorthSouth" />

        <Border Grid.Row="4" Padding="14" CornerRadius="10" Background="#101C1C1C">
          <Grid RowDefinitions="Auto,*" RowSpacing="10">
            <TextBlock x:Name="OperationHeaderTextBlock" Text="Registro" FontWeight="SemiBold" />
            <TextBox Grid.Row="1"
                     x:Name="LogTextBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
